# Application
APP_NAME=People Counting System
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/people_counting

# Security
SECRET_KEY=change-me-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# AI Worker
WORKER_ENABLED=true
WORKER_POLL_INTERVAL_SECONDS=30
WORKER_YOLO_MODEL=yolo11n.pt
WORKER_CONFIDENCE_THRESHOLD=0.5
WORKER_IOU_THRESHOLD=0.5
WORKER_LINE_Y_RATIO=0.5
WORKER_FRAME_SKIP=2
WORKER_RECONNECT_DELAY_SECONDS=5
WORKER_MAX_RECONNECT_ATTEMPTS=0
WORKER_TRACKER_CONFIG=bytetrack.yaml
WORKER_RTSP_TRANSPORT=tcp

# Redis / Real-time
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
REDIS_LIVE_COUNTS_CHANNEL=live_counts
REDIS_RECONNECT_DELAY_SECONDS=3
REDIS_MAX_RECONNECT_ATTEMPTS=0
